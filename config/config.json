{
  "feishu": {
    "app_id": "",
    "app_secret": "",
    "attachment_sync": true,
    "bitable_url": "",
    "meta_sync": [
      "type",
      "impact_factor",
      "journal_tags",
      "abstract",
      "tags",
      "collections",
      "url"
    ]
