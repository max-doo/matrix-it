{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MatrixIt",
  "version": "1.0.0",
  "identifier": "com.matrixit.app",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../frontend"
    },
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../frontend"
    },
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MatrixIt",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/matrixit-sidecar"
    ],
    "resources": [
      "resources/jcr.db",
      "resources/config.default.json"
    ],
    "windows": {
      "wix": {
        "language": {
          "zh-CN": {
            "localePath": "wix/locales/zh-CN.wxl"
          }
        },
        "fragmentPaths": [
          "wix/fragments/ui-custom.wxs"
        ],
        "componentRefs": [
          "DesktopShortcut"
        ]
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": [
          "SimpChinese"
        ],
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}